# ================================
# 环境配置
# ================================
# 可选值：development（开发环境）或 production（生产环境）
# development: 开启详细日志输出，便于调试
# production: 关闭详细日志输出，提升性能
ENV=development

# ================================
# 百度千帆 LLM 配置（必填）
# ================================
# 从 https://qianfan.baidubce.com/ 获取 API Key
QIANFAN_API_KEY=your_qianfan_api_key_here

# 千帆 Coding API 地址
QIANFAN_BASE_URL=https://qianfan.baidubce.com/v2/coding

# 千帆模型配置
QIANFAN_MODEL=qianfan-code-latest

# ================================
# 智谱 AI Embedding 配置（必填）
# ================================
# 从 https://open.bigmodel.cn/ 获取 API Key
ZHIPU_API_KEY=your_zhipu_api_key_here

# 智谱 Embedding API 配置
ZHIPU_EMBEDDING_API_URL=https://open.bigmodel.cn/api/paas/v4/embeddings
ZHIPU_EMBEDDING_MODEL=embedding-3
ZHIPU_EMBEDDING_DIMENSIONS=1024

# ================================
# PostgreSQL 数据库配置（必填 - 用于代码查询功能）
# ================================
# 数据库主机地址
DB_HOST=localhost
# 数据库端口
DB_PORT=5432
# 数据库名称
DB_NAME=quantagent
# 数据库用户名
DB_USER=postgres
# 数据库密码（必填，否则代码查询功能无法使用）
DB_PASSWORD=your_db_password

# ================================
# Redis 配置（必填 - 用于会话缓存）
# ================================
# Redis 主机地址
REDIS_HOST=localhost
# Redis 端口
REDIS_PORT=6379
# Redis 数据库编号
REDIS_DB=0
# Redis 密码（可选）
# REDIS_PASSWORD=your_redis_password

# ================================
# 会话管理配置（可选）
# ================================
# 模型上下文窗口大小（tokens）
MODEL_CONTEXT_WINDOW=128000
# 最大输出 tokens
MAX_OUTPUT_TOKENS=4096
# System Prompt 预算（tokens）
SYSTEM_PROMPT_BUDGET=2000
# 工具 Schema 预算（tokens）
TOOL_SCHEMA_BUDGET=1000
# 安全余量（tokens）
SAFETY_MARGIN=1000

# 单条消息最大长度（字符）
MAX_MESSAGE_LENGTH=50000
# 单条消息最大 tokens
MAX_MESSAGE_TOKENS=16000

# 会话空闲过期时间（秒，默认7天）
SESSION_IDLE_TTL=604800
# 会话锁过期时间（秒）
SESSION_LOCK_TTL=120
# 会话锁超时时间（秒）
SESSION_LOCK_TIMEOUT=10
# Redis 最大消息数
REDIS_MAX_MESSAGES=100

# ================================
# 股票 API 配置（可选）
# ================================

# 股票数据 API 基础 URL
STOCK_API_BASE_URL=http://localhost:8001

# ================================
# Qdrant 向量数据库配置（可选）
# ================================
QDRANT_HOST=localhost
# GRPC 端口（默认 6334），HTTP 端口为 6333
QDRANT_PORT=6334
QDRANT_COLLECTION_NAME=QuantAgent
QDRANT_USE_GRPC=true

# ================================
# 应用配置
# ================================
APP_NAME=QuantAgent
APP_VERSION=1.0.0
DEBUG=false

# ================================
# 服务器配置
# ================================
# 服务器监听地址（生产环境建议使用反向代理）
# 127.0.0.1 仅本地访问，0.0.0.0 监听所有接口（需配合防火墙）
HOST=127.0.0.1
# 服务器端口
PORT=8001

# ================================
# 百度智能云 Reranker 配置（可选）
# ================================
# 从 https://cloud.baidu.com/ 获取 API Key
# 用于对检索结果进行重排序，提升相关性
BAIDU_RERANKER_API_KEY=your_baidu_reranker_api_key_here
BAIDU_RERANKER_MODEL=qwen3-reranker-8b
BAIDU_RERANKER_BASE_URL=https://qianfan.baidubce.com/v2/rerank
BAIDU_RERANKER_TOP_N=10
