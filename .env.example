# ================================
# 环境配置
# ================================
# 可选值：development（开发环境）或 production（生产环境）
# development: 开启详细日志输出，便于调试
# production: 关闭详细日志输出，提升性能
ENV=development

# ================================
# 智谱 AI 配置（必填）
# ================================
# 从 https://open.bigmodel.cn/ 获取 API Key
ZHIPU_AI_API_KEY=your_api_key_here

# 智谱 AI Chat API 地址
ZHIPU_AI_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# 智谱 AI 模型配置
ZHIPU_AI_MODEL=glm-4.5-air

# 智谱 Embedding API 配置
ZHIPU_EMBEDDING_API_URL=https://open.bigmodel.cn/api/paas/v4/embeddings
ZHIPU_EMBEDDING_MODEL=embedding-3
ZHIPU_EMBEDDING_DIMENSIONS=1024

# ================================
# PostgreSQL 数据库配置（可选）
# ================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=quantagent
DB_USER=postgres
DB_PASSWORD=your_db_password

# ================================
# 股票 API 配置（可选）
# ================================
# 股票数据 API 基础 URL
STOCK_API_BASE_URL=http://localhost:8000

# ================================
# Qdrant 向量数据库配置（可选）
# ================================
QDRANT_HOST=localhost
QDRANT_PORT=6334
QDRANT_COLLECTION_NAME=QuantAgent
QDRANT_USE_GRPC=true

# ================================
# 应用配置
# ================================
APP_NAME=QuantAgent
APP_VERSION=1.0.0
DEBUG=true
